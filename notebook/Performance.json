				"source": [
					"#How to reorder columns in Delta table for better performance in Databricks PySpark\n",
					"spark.sql(f'ALTER TABLE {db_notebookname}.{db_tablename} ALTER COLUMN Nem12HashKey FIRST;')\n",
					"spark.sql(f'ALTER TABLE {db_notebookname}.{db_tablename} ALTER COLUMN Nem12HashDiff AFTER Nem12HashKey;')\n",
					"spark.sql(f'ALTER TABLE {db_notebookname}.{db_tablename} ALTER COLUMN CDC_CurrentFlag AFTER Nem12HashDiff;')"
				],
				"execution_count": null
