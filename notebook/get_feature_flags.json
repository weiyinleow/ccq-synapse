				"cell_type": "code",
				"source": [
					"db_query = f\"SELECT FlagName, FlagState FROM CTL.DEV_FEATURE_FLAGS\"\n",
					"\n",
					"df_feature_flags = spark.read.format(\"jdbc\") \\\n",
					"    .option(\"url\", \"jdbc:sqlserver://%s:%s\" % (sql_server_name, db_port)) \\\n",
					"    .option(\"query\", db_query) \\\n",
					"    .option(\"accessToken\", access_token) \\\n",
					"    .option(\"encrypt\", \"true\") \\\n",
					"    .option(\"databaseName\", db_name) \\\n",
					"    .option(\"hostNameInCertificate\", \"*.database.windows.net\") \\\n",
					"    .load()"
				],
